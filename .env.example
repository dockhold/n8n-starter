# --- Set BEFORE your first deploy ---
# A stable secret that encrypts saved credentials. Put it in the Vault (not a
# plain variable). If you don't set it, n8n generates one that lives on the
# ephemeral disk and is LOST on restart — making all saved credentials
# unrecoverable. Generate one with: openssl rand -hex 16
N8N_ENCRYPTION_KEY=replace-with-a-stable-random-secret

# --- Set AFTER the first deploy, once you know your app's URL ---
# So the editor and webhook URLs are correct behind the HTTPS edge:
#   N8N_HOST=your-app-xxxx.dockhold.app
#   WEBHOOK_URL=https://your-app-xxxx.dockhold.app/

# --- Handled for you ---
# DATABASE_URL is injected by the managed database add-on (enable it!). The
# entrypoint maps it to n8n's DB_TYPE / DB_POSTGRESDB_* automatically. PORT,
# the listen address, the user folder, and HTTPS/proxy settings are set too.
